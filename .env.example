# Lumine Production Environment Variables
# Copy this file to .env and replace the values before deployment.

# ==========================================
# BACKEND (FastAPI / Celery)
# ==========================================

# Security
SECRET_KEY=generate_a_secure_random_string_here_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# For production, replace sqlite with PostgreSQL:
# SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://user:password@db_host:5432/lumine
SQLALCHEMY_DATABASE_URI=sqlite+aiosqlite:///./lumine.db

# Redis & Celery
# Redis is required for WebSockets and Celery background tasks
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS & Networking
# Space-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:3000 https://lumineai.vercel.app

# OpenAI Integration
# Required for generating dynamic skincare reports and the AI assistant
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Storage
# Can be local (for dev) or s3 (for production)
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# ==========================================
# FRONTEND (Next.js)
# ==========================================
# The frontend requires NEXT_PUBLIC prefixed variables to access them in the browser.

# Base URL for the FastAPI backend
NEXT_PUBLIC_API_URL=https://api.lumineai.vercel.app
